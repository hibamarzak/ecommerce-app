package ui;

import java.util.Scanner;

public class MainMenu {

    private Scanner scanner;
    private AuthMenu authMenu;

    public MainMenu() {
        this.scanner  = new Scanner(System.in);
        this.authMenu = new AuthMenu(scanner);
    }

    /**
     * Point d'entrée principal de l'interface utilisateur
     */
    public void demarrer() {
        System.out.println("Connexion au serveur...");
        // TODO: initialiser ClientTCP ici et le passer à AuthMenu
        // ClientTCP client = new ClientTCP("localhost", 5000);
        // client.connecter();
        // authMenu.setClient(client);

        // Étape 1: Authentification
        boolean connecte = authMenu.afficherMenu();

        if (!connecte) {
            System.out.println("Impossible de se connecter. Fermeture.");
            return;
        }

        // Étape 2: Menu principal
        afficherMenuPrincipal();
    }

    /**
     * Affiche le menu principal (après connexion)
     */
    private void afficherMenuPrincipal() {
        boolean quitter = false;

        while (!quitter) {
            System.out.println("\n========================================");
            System.out.println("  MENU PRINCIPAL - " + authMenu.getUsername().toUpperCase());
            System.out.println("========================================");
            System.out.println("  1. Voir les produits");
            System.out.println("  2. Mon panier");
            System.out.println("  3. Mes commandes");
            System.out.println("  4. Mon profil");
            System.out.println("  9. Se déconnecter");
            System.out.println("  0. Quitter");
            System.out.println("----------------------------------------");
            System.out.print("Votre choix: ");

            String choix = scanner.nextLine().trim();

            switch (choix) {
                case "1":
                    // TODO: lancer ProductMenu (Oumaima)
                    System.out.println("[→] Module Produits (Oumaima)");
                    break;
                case "2":
                    // TODO: lancer CartMenu (Oumaima)
                    System.out.println("[→] Module Panier (Oumaima)");
                    break;
                case "3":
                    // TODO: lancer OrderMenu (Ali)
                    System.out.println("[→] Module Commandes (Ali)");
                    break;
                case "4":
                    afficherMenuProfil();
                    break;
                case "9":
                    authMenu.seDeconnecter();
                    // Retourner au menu d'authentification
                    boolean reconnecte = authMenu.afficherMenu();
                    if (!reconnecte) quitter = true;
                    break;
                case "0":
                    quitter = true;
                    System.out.println("Au revoir, " + authMenu.getUsername() + " !");
                    break;
                default:
                    System.out.println("[!] Choix invalide.");
            }
        }

        scanner.close();
    }

    /**
     * Affiche et gère le menu profil utilisateur
     */
    private void afficherMenuProfil() {
        System.out.println("\n--- MON PROFIL ---");
        System.out.println("Utilisateur : " + authMenu.getUsername());
        System.out.println("Rôle        : " + authMenu.getUserRole());
        System.out.println("ID          : " + authMenu.getUserId());

        System.out.println("\n  1. Modifier mes informations");
        System.out.println("  0. Retour");
        System.out.print("Votre choix: ");

        String choix = scanner.nextLine().trim();
        if (choix.equals("1")) {
            afficherFormulaireModificationProfil();
        }
    }

    /**
     * Formulaire de modification du profil
     */
    private void afficherFormulaireModificationProfil() {
        System.out.println("\n--- MODIFIER MON PROFIL ---");

        System.out.print("Nouvel email (laisser vide pour ne pas changer): ");
        String email = scanner.nextLine().trim();

        System.out.print("Téléphone: ");
        String telephone = scanner.nextLine().trim();

        System.out.print("Adresse: ");
        String adresse = scanner.nextLine().trim();

        // Construire et envoyer la requête
        // TODO: String requete = "UPDATE_PROFIL:" + authMenu.getUserId() + ":" + email + ":" + telephone + ":" + adresse;
        // client.envoyerRequete(requete);

        System.out.println("[✓] Profil mis à jour (à connecter au serveur).");
    }

    /**
     * Point d'entrée de l'application
     */
    public static void main(String[] args) {
        MainMenu menu = new MainMenu();
        menu.demarrer();
    }
}
